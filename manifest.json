{
  "manifest_version": 3,
  "name": "Color Cleaner für E-Mails",
  "version": "1.2.1",
  "description": "Entfernt beim Senden explizite Text- und Hintergrundfarben aus dem HTML-Body, damit E-Mails im Dark- und Light-Mode des Empfängers lesbar bleiben.",
  "author": "Color Cleaner",

  "browser_specific_settings": {
    "gecko": {
      "id": "color-cleaner@local.addon",
      "strict_min_version": "115.0"
    }
  },

  "permissions": [
    "compose",
    "compose.send",
    "storage"
  ],

  "background": {
    "scripts": ["content/colorCleaner.js", "background.js"]
  },

  "compose_action": {
    "default_title": "Farbbereinigung aktiv – klicken zum Deaktivieren für diese E-Mail",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },

  "action": {
    "default_title": "Color Cleaner",
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "96": "icons/icon-96.png"
    }
  },

  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  }
}
